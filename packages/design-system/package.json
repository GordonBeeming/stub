{
  "name": "@gordonbeeming/design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared design system for the stub monorepo — tokens, fonts, components, Tailwind preset.",
  "sideEffects": ["./src/tokens.css", "./src/components/styles.css", "./dist/fonts.js"],
  "files": ["dist", "src/tokens.css", "src/components/styles.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./styles.css": "./src/components/styles.css",
    "./fonts": {
      "types": "./dist/fonts.d.ts",
      "import": "./dist/fonts.js"
    },
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.js"
    },
    "./theme-toggle": {
      "types": "./dist/theme-toggle.d.ts",
      "import": "./dist/theme-toggle.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.0",
    "@fontsource/instrument-serif": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
