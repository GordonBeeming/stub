{
  "name": "@stub/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The stub app — short links and client-side-encrypted burn notes on Cloudflare Workers.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf .next .open-next .turbo",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview -- --local-protocol=https",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@gordonbeeming/design-system": "workspace:*",
    "@opennextjs/cloudflare": "^1.19.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "jose": "^6.2.2",
    "nanoid": "^5.1.9",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@eslint/eslintrc": "^3.3.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.2.4",
    "typescript": "^5.6.3",
    "wrangler": "^4.0.0"
  }
}
