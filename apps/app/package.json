{
  "name": "@stub/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The stub app — short links + client-side-encrypted burn notes on a Hono Worker + React SPA via @cloudflare/vite-plugin.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist .wrangler .vite",
    "cf:deploy": "vite build && wrangler deploy",
    "cf:typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@gordonbeeming/design-system": "workspace:*",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "hono": "^4.10.5",
    "jose": "^6.2.2",
    "nanoid": "^5.1.9",
    "resend": "^6.12.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "wouter": "^3.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.12.7",
    "@cloudflare/workers-types": "^4.20250410.0",
    "@playwright/test": "^1.49.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.15.0",
    "typescript": "^5.6.3",
    "vite": "^6.4.1",
    "wrangler": "^4.84.0"
  }
}
