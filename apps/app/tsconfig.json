{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "allowJs": false,
    "types": ["@cloudflare/workers-types", "vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@worker/*": ["./src/worker/*"],
      "@app/*": ["./src/react-app/*"]
    }
  },
  "include": ["cloudflare-env.d.ts", "src/**/*.ts", "src/**/*.tsx", "vite.config.ts"],
  "exclude": ["node_modules", "dist", ".wrangler"]
}
